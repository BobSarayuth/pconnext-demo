HOST=localhost
PORT=3000
LOG_NAME=bobby-ai
LOG_LEVEL=info
LOG_FORMAT=text

# Database and cache settings
AGENTIC_DB_URI=postgresql://localhost:5433/postgres
AGENTIC_CACHE_URI=redis://:password@localhost:6380/2
AGENTIC_IMAGE_WISHLIST=i.ibb.co,localhost

# API Key :: openssl rand -base64 32
AGENTIC_API_KEY=
AGENTIC_CORS_WISHLIST=http://localhost:4321,https://chat-ui-dev.scg-wedo.tech

# Public chat JWT auth after AD/Entra login
# Frontend should call /api/chat/* with: Authorization: Bearer <access_token>
AGENTIC_JWT_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
AGENTIC_JWT_AUDIENCE=<api-client-id-or-application-id-uri>
AGENTIC_JWT_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
AGENTIC_JWT_ALGORITHMS=RS256

# Chat UI AD/Entra login gate
AUTH_ENABLED=true
AUTH_TENANT_ID=<tenant-id>
AUTH_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
AUTH_CLIENT_ID=<ui-or-api-client-id>
AUTH_BASE_PATH=
AUTH_REDIRECT_URI=http://localhost:8080/auth/callback
AUTH_SCOPE=openid profile email
AUTH_PROXY_TOKEN_TYPE=auto
AUTH_COOKIE_SECURE=false

# Content service settings
CAP_CONTENT_SERVICE_URL=http://localhost:3080
CAP_CONTENT_TOKEN_URL=http://localhost:3080/oauth/token
CAP_CONTENT_CLIENT_ID=client-id
CAP_CONTENT_CLIENT_SECRET=client-secret
CAP_CONTENT_AUDIENCE=http://localhost:3080
CAP_CONTENT_KNOWLEDGE_INDEX=home-content-article


# Model settings
AGENTIC_AGENT_MODEL=litellm/azure/scgdigital-vertex-gemini-2.0-flash-001
AGENTIC_SAFEGUARD_MODEL=litellm/azure/scgdigital-azure-gpt-4o-mini
AGENTIC_INSPECT_MODEL=litellm/azure/scgdigital-azure-gpt-4o-mini

# LiteLLM settings
LITELLM_BASE_URL=https://do-cap-litellm-dev.scg-wedo.tech
LITELLM_API_KEY=your_litellm_agentic_api_key
LITELLM_LOG=ERROR
# AI Model API Keys
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional settings
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
